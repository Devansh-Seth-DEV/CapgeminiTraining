<?xml version="1.0" encoding="UTF-8"?>
<configuration>
	<appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="APPLOG_FILE" class="ch.qos.logback.core.FileAppender">
		<file>app.log</file>
		<append>true</append>
		<encoder>
			<pattern>%-4relative [%thread] %-5level %logger{35} - %msg%n</pattern>
		</encoder>
	</appender>

	<appender name="APPLOG_ERRFILE"
		class="ch.qos.logback.core.FileAppender">
		<file>apperrors.log</file>
		<append>true</append>
		<encoder>
			<pattern>%-4relative [%thread] %-5level %logger{35} - %msg%n</pattern>
		</encoder>
	</appender>

	<logger name="com.gal" level="DEBUG">
		<appender-ref ref="APPLOG_FILE" />
		<appender-ref ref="STDOUT" />
	</logger>

	<logger name="com" level="ERROR">
		<appender-ref ref="APPLOG_ERRFILE" />
	</logger>

	<!-- Set the logging level for Hibernate to WARN to reduce verbosity -->
	<logger name="org.hibernate" level="INFO">
		<appender-ref ref="STDOUT" />
	</logger>

	<!-- Optional: set specific categories to INFO for detailed info -->
	<logger name="org.springframework" level="INFO" />
	<logger name="org.springframework.boot" level="INFO" /> <!-- Logs JDBC
	parameters -->

	<root level="DEBUG">
		<appender-ref ref="STDOUT" />
	</root>
</configuration>